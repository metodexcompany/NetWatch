<Window x:Class="NetWatch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NetWatch"
        Title="NetWatch" Width="1200" Height="780"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/GlassmorphismTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="14" Background="{StaticResource BgDarkBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══ Заголовок ═══ -->
            <Border Grid.Row="0" Background="{StaticResource BgPanelBrush}"
                    CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" Fill="{StaticResource GreenBrush}" Margin="0,0,12,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="NETWATCH" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatsText" Margin="20,0,0,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource GreenBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="Безопасно" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource YellowBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="Неизвестно" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                        <Ellipse Width="8" Height="8" Fill="{StaticResource RedBrush}" Margin="0,0,4,0"/>
                        <TextBlock Text="Угроза" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <!-- Кнопка обновить -->
                        <Button Content="⟳ Обновить" Click="Refresh_Click" Style="{StaticResource RoundBtn}"
                                Background="#15202A" Foreground="{StaticResource AccentBrush}"
                                BorderBrush="#1E3A5A" FontSize="11" Padding="10,4" Margin="0,0,10,0"/>
                        <!-- Настройки -->
                        <Button Content="⚙" Click="Settings_Click" Style="{StaticResource WinBtn}"
                                Foreground="{StaticResource TextSecondaryBrush}" FontSize="16"/>
                        <!-- Алерты -->
                        <Border x:Name="AlertBadge" Background="#F85149" CornerRadius="10"
                                Padding="8,2" Margin="0,0,10,0" Cursor="Hand"
                                MouseLeftButtonDown="AlertBadge_Click" Visibility="Collapsed">
                            <TextBlock x:Name="AlertBadgeText" Text="0" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <Button Content="—" Click="Minimize_Click" Style="{StaticResource WinBtn}"
                                Foreground="{StaticResource TextSecondaryBrush}" FontSize="16"/>
                        <Button x:Name="MaxBtn" Content="□" Click="Maximize_Click" Style="{StaticResource WinBtn}"
                                Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                        <Button Content="✕" Click="Close_Click" Style="{StaticResource WinBtn}"
                                Foreground="{StaticResource RedBrush}" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ Панель алертов ═══ -->
            <Border x:Name="AlertPanel" Grid.Row="1" Visibility="Collapsed" Panel.ZIndex="100"
                    Background="#E00B1120" CornerRadius="0,0,14,14">
                <Border Style="{StaticResource GlassPanel}" Margin="180,30,180,30"
                        VerticalAlignment="Top" MaxHeight="420">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="ПОДОЗРИТЕЛЬНЫЕ СОЕДИНЕНИЯ" FontSize="14"
                                       FontWeight="Bold" Foreground="#F85149" VerticalAlignment="Center"/>
                            <Button Content="Закрыть и очистить" HorizontalAlignment="Right"
                                    Click="DismissAlerts_Click" Style="{StaticResource BanBtn}"
                                    FontSize="11" Padding="14,6"/>
                        </Grid>
                        <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Alerts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" BorderBrush="#1E2D3D" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding TimeStr}" FontSize="11" Foreground="#5A6A7A" Width="60"/>
                                                    <TextBlock Text="{Binding Process}" FontSize="13" FontWeight="Bold" Foreground="#F07178"/>
                                                    <TextBlock FontSize="13" Foreground="#8B949E" Margin="10,0,0,0">
                                                        <Run Text="→  "/><Run Text="{Binding IP, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding Port, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Org}" FontSize="12" Foreground="#6B7B8D" Margin="60,4,0,0"/>
                                                <TextBlock Text="{Binding Reason}" FontSize="11" Foreground="#E3B341" Margin="60,2,0,0"/>
                                                <TextBlock Text="{Binding ExePath}" FontSize="10" Foreground="#4A5A6A" Margin="60,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ═══ Панель настроек ═══ -->
            <Border x:Name="SettingsPanel" Grid.Row="1" Visibility="Collapsed" Panel.ZIndex="100"
                    Background="#E00B1120" CornerRadius="0,0,14,14">
                <Border Style="{StaticResource GlassPanel}" Margin="250,40,250,40"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <TextBlock Text="НАСТРОЙКИ" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                            <Button Content="✕" HorizontalAlignment="Right" Click="CloseSettings_Click"
                                    Style="{StaticResource WinBtn}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14"/>
                        </Grid>
                        <!-- GeoIP -->
                        <Border Background="#0B1120" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Определение геолокации IP" FontSize="13" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                                    <TextBlock Text="Отправляет IP-адреса в сервис ip-api.com (серверы в США) для определения страны и организации. Без этого все адреса будут отображаться без геоданных."
                                               FontSize="11" Foreground="#6B7B8D" TextWrapping="Wrap" Margin="0,4,60,0"/>
                                </StackPanel>
                                <CheckBox x:Name="GeoIPToggle" IsChecked="{Binding GeoIPEnabled}"
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="GeoIPToggle_Changed" Unchecked="GeoIPToggle_Changed"/>
                            </Grid>
                        </Border>
                        <!-- Показывать свои соединения -->
                        <Border Background="#0B1120" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Показывать соединения NetWatch" FontSize="13" FontWeight="SemiBold" Foreground="#C9D1D9"/>
                                    <TextBlock Text="Показывать собственные соединения приложения (GeoIP запросы) в общем списке одной строкой."
                                               FontSize="11" Foreground="#6B7B8D" TextWrapping="Wrap" Margin="0,4,60,0"/>
                                </StackPanel>
                                <CheckBox x:Name="ShowSelfToggle" IsChecked="{Binding ShowSelfConnections}"
                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                          Checked="ShowSelfToggle_Changed" Unchecked="ShowSelfToggle_Changed"/>
                            </Grid>
                        </Border>
                        <!-- Интервал обновления -->
                        <Border Background="#0B1120" CornerRadius="8" Padding="14">
                            <StackPanel>
                                <TextBlock Text="Интервал обновления" FontSize="13" FontWeight="SemiBold" Foreground="#C9D1D9" Margin="0,0,0,6"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="1 сек" Click="Interval1_Click" Style="{StaticResource RoundBtn}"
                                            Background="#15202A" Foreground="#7EB8F7" BorderBrush="#1E3A5A" Margin="0,0,6,0" Padding="10,4"/>
                                    <Button Content="3 сек" Click="Interval3_Click" Style="{StaticResource RoundBtn}"
                                            Background="#1E3A5A" Foreground="#7EB8F7" BorderBrush="#2A5A8A" Margin="0,0,6,0" Padding="10,4"/>
                                    <Button Content="5 сек" Click="Interval5_Click" Style="{StaticResource RoundBtn}"
                                            Background="#15202A" Foreground="#7EB8F7" BorderBrush="#1E3A5A" Margin="0,0,6,0" Padding="10,4"/>
                                    <Button Content="10 сек" Click="Interval10_Click" Style="{StaticResource RoundBtn}"
                                            Background="#15202A" Foreground="#7EB8F7" BorderBrush="#1E3A5A" Padding="10,4"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ═══ Основной контент ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ Боковая панель ═══ -->
                <Border Grid.Column="0" Background="#0D1525" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0"
                        CornerRadius="0,0,0,14">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Processes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" BorderBrush="#151D2E" BorderThickness="0,0,0,1"
                                            Cursor="Hand" MouseLeftButtonDown="Process_Click" Tag="{Binding Name}"
                                            ToolTip="{Binding ExePath}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#151D2E"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="34" Height="34" CornerRadius="8" Background="#7EB8F720" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding Icon}" FontSize="12" FontWeight="Bold"
                                                           Foreground="#7EB8F7" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel MaxWidth="140" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#C9D1D9" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                    <TextBlock FontSize="11" Foreground="#6B7B8D" Margin="0,0,8,0">
                                                        <Run Text="{Binding Count, Mode=OneWay}"/><Run Text=" подкл."/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="10"
                                                               Foreground="{Binding IsSigned, Converter={x:Static local:Converters.SignedColorConv}}"
                                                               Text="{Binding IsSigned, Converter={x:Static local:Converters.SignedTextConv}}"/>
                                                </StackPanel>
                                                <Button Content="⛔ Блок. всё" Style="{StaticResource BanBtn}"
                                                        Margin="0,4,0,0" FontSize="9" Padding="6,2"
                                                        HorizontalAlignment="Left"
                                                        Command="{Binding DataContext.BlockProcessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Name}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- ═══ Дашборд ═══ -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <!-- Карточки статистики -->
                        <UniformGrid Columns="5" Margin="0,0,0,16">
                            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding TotalConns}" FontSize="30" FontWeight="Bold" Foreground="#7EB8F7"/>
                                    <TextBlock Text="ПОДКЛЮЧЕНИЙ" FontSize="10" Foreground="#6B7B8D" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SafeCount}" FontSize="30" FontWeight="Bold" Foreground="#34D058"/>
                                    <TextBlock Text="БЕЗОПАСНЫХ" FontSize="10" Foreground="#6B7B8D" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding UnknownCount}" FontSize="30" FontWeight="Bold" Foreground="#E3B341"/>
                                    <TextBlock Text="НЕИЗВЕСТНЫХ" FontSize="10" Foreground="#6B7B8D" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding SuspiciousCount}" FontSize="30" FontWeight="Bold" Foreground="#F85149"/>
                                    <TextBlock Text="УГРОЗ" FontSize="10" Foreground="#6B7B8D" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="↓" FontSize="16" Foreground="#34D058"/>
                                        <TextBlock Text="{Binding DownloadMbps, StringFormat='{}{0:F2}'}" FontSize="18" FontWeight="Bold" Foreground="#34D058" Margin="4,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="↑" FontSize="16" Foreground="#E3B341"/>
                                        <TextBlock Text="{Binding UploadMbps, StringFormat='{}{0:F2}'}" FontSize="18" FontWeight="Bold" Foreground="#E3B341" Margin="4,0"/>
                                    </StackPanel>
                                    <TextBlock Text="МБИТ/С" FontSize="10" Foreground="#6B7B8D" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Топ сервисов -->
                        <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="ПОПУЛЯРНЫЕ СЕРВИСЫ" FontSize="12" FontWeight="SemiBold" Foreground="#8B9BAB" Margin="0,0,0,12"/>
                                <ItemsControl ItemsSource="{Binding TopServices}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,6" Height="26">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13"
                                                           Foreground="#C9D1D9" TextAlignment="Right" Margin="0,0,12,0"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <Border Grid.Column="1" Background="#0B1120" CornerRadius="4" Height="22">
                                                    <Grid>
                                                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                                                Background="{Binding Risk, Converter={x:Static local:Converters.RiskToBrushConv}}">
                                                            <Border.Width>
                                                                <MultiBinding Converter="{x:Static local:Converters.PercentWidthConv}">
                                                                    <Binding Path="Percent"/>
                                                                    <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border, AncestorLevel=2}"/>
                                                                </MultiBinding>
                                                            </Border.Width>
                                                        </Border>
                                                        <TextBlock Text="{Binding Count}" FontSize="11" FontWeight="Bold"
                                                                   Foreground="White" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Заблокированные IP -->
                        <Border Style="{StaticResource GlassPanel}" Margin="0,0,0,16"
                                Visibility="{Binding BlockedIPs.Count, Converter={x:Static local:Converters.CountToVisConv}}">
                            <StackPanel>
                                <TextBlock Text="ЗАБЛОКИРОВАННЫЕ IP" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#F85149" Margin="0,0,0,12"/>
                                <ItemsControl ItemsSource="{Binding BlockedIPs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="6,6" BorderBrush="#1A2435" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding}" FontSize="14"
                                                               FontFamily="Cascadia Code,Consolas" Foreground="#F85149"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1" Content="Разблокировать" Style="{StaticResource UnbanBtn}"
                                                            Command="{Binding DataContext.UnblockCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Все соединения -->
                        <Border Style="{StaticResource GlassPanel}">
                            <StackPanel>
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#8B9BAB" Margin="0,0,0,12">
                                    <Run Text="ВСЕ ПОДКЛЮЧЕНИЯ ("/>
                                    <Run Text="{Binding AllConnections.Count, Mode=OneWay}"/>
                                    <Run Text=")"/>
                                </TextBlock>
                                <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AllConnections}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="4,6" BorderBrush="#1A2435" BorderThickness="0,0,0,1" Margin="0,0,0,2">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="16"/>
                                                            <ColumnDefinition Width="95"/>
                                                            <ColumnDefinition Width="95"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="75"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Grid.Column="0" Width="10" Height="10"
                                                                 Fill="{Binding Risk, Converter={x:Static local:Converters.RiskToBrushConv}}"
                                                                 VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ProcessName}" FontSize="13"
                                                                   FontWeight="SemiBold" Foreground="#7EB8F7"
                                                                   TextTrimming="CharacterEllipsis" Margin="6,0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding Service}" FontSize="12"
                                                                   Foreground="#8BC48A" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="3" FontSize="12" Foreground="#6B7B8D"
                                                                   FontFamily="Cascadia Code,Consolas" VerticalAlignment="Center">
                                                            <Run Text="{Binding RemoteIP, Mode=OneWay}"/><Run Text=":"/><Run Text="{Binding RemotePort, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="4" Text="{Binding DisplayCount}" FontSize="11"
                                                                   FontWeight="Bold" Foreground="#E3B341" VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Grid.Column="5" Text="{Binding Country}" FontSize="12"
                                                                   Foreground="#6B7B8D" TextAlignment="Right" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="6" Content="⛔ Блок" Style="{StaticResource BanBtn}"
                                                                Margin="8,0,0,0"
                                                                Command="{Binding DataContext.BlockCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding RemoteIP}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
