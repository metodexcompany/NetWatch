<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <Color x:Key="BgDark">#0B1120</Color>
    <Color x:Key="BgPanel">#151D2E</Color>
    <Color x:Key="BgCard">#1A2435</Color>
    <Color x:Key="Border">#1E2D3D</Color>
    <Color x:Key="TextPrimary">#C9D1D9</Color>
    <Color x:Key="TextSecondary">#6B7B8D</Color>
    <Color x:Key="Accent">#7EB8F7</Color>
    <Color x:Key="Green">#34D058</Color>
    <Color x:Key="Yellow">#E3B341</Color>
    <Color x:Key="Red">#F85149</Color>

    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgPanelBrush" Color="{StaticResource BgPanel}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}"/>
    <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource Yellow}"/>
    <SolidColorBrush x:Key="RedBrush" Color="{StaticResource Red}"/>

    <!-- Glass panel style -->
    <Style x:Key="GlassPanel" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#1A2435" Opacity="0.7"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.08"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="18"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
    </Style>

    <!-- Card style -->
    <Style x:Key="StatCard" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="#1A2435" Opacity="0.6"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="#FFFFFF" Opacity="0.06"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- Rounded button base -->
    <Style x:Key="RoundBtn" TargetType="Button">
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ban button -->
    <Style x:Key="BanBtn" TargetType="Button" BasedOn="{StaticResource RoundBtn}">
        <Setter Property="Background" Value="#2A1520"/>
        <Setter Property="Foreground" Value="#F85149"/>
        <Setter Property="BorderBrush" Value="#5A2020"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,5"/>
    </Style>

    <!-- Unban button -->
    <Style x:Key="UnbanBtn" TargetType="Button" BasedOn="{StaticResource RoundBtn}">
        <Setter Property="Background" Value="#152A15"/>
        <Setter Property="Foreground" Value="#34D058"/>
        <Setter Property="BorderBrush" Value="#205A20"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,5"/>
    </Style>

    <!-- Window control button -->
    <Style x:Key="WinBtn" TargetType="Button" BasedOn="{StaticResource RoundBtn}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="28"/>
    </Style>

    <!-- Scrollbar style -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

</ResourceDictionary>
